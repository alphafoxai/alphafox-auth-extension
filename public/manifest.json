{
  "manifest_version": 3,
  "name": "AlphaFox Auth Sync",
  "version": "2.2.0",
  "description": "Sync supported exchange web login information to AlphaFox.",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://alphafox.app/*",
    "https://*.alphafox.app/*",
    "https://www.binance.com/*",
    "https://binance.com/*",
    "https://*.binance.com/*",
    "https://www.suitechsui.online/*",
    "https://suitechsui.online/*",
    "https://*.suitechsui.online/*",
    "https://www.okx.com/*",
    "https://okx.com/*",
    "https://*.okx.com/*",
    "https://www.bitget.com/*",
    "https://bitget.com/*",
    "https://*.bitget.com/*",
    "https://www.bitgetapps.com/*",
    "https://bitgetapps.com/*",
    "https://*.bitgetapps.com/*",
    "https://www.bybit.com/*",
    "https://bybit.com/*",
    "https://*.bybit.com/*",
    "https://www.gate.io/*",
    "https://gate.io/*",
    "https://*.gate.io/*",
    "https://www.gate.com/*",
    "https://gate.com/*",
    "https://*.gate.com/*"
  ],
  "action": {
    "default_title": "AlphaFox Auth Sync",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
