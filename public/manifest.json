{
  "manifest_version": 3,
  "name": "AlphaFox Auth Sync",
  "version": "2.0.1",
  "description": "Read Binance cookie_csrf credentials and sync them to AlphaFox.",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://alphafox.app/*",
    "https://*.alphafox.app/*",
    "https://www.binance.com/*",
    "https://binance.com/*",
    "https://*.binance.com/*",
    "https://www.suitechsui.online/*",
    "https://suitechsui.online/*",
    "https://*.suitechsui.online/*"
  ],
  "action": {
    "default_title": "AlphaFox Auth Sync",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
